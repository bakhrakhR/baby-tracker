# Client config for the Svelte app (Vite exposes VITE_* to the browser).
# These values are PUBLIC by design (they ship in the client bundle):
#   - the publishable key is meant to be embedded in clients
#   - RLS + the auth-telegram JWT are what actually protect the data
# Copy to .env and fill in.

VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
VITE_AUTH_FUNCTION_URL=https://<project-ref>.supabase.co/functions/v1/auth-telegram

# Dev-only: a signed initData string to authenticate when running outside
# Telegram (plain browser). Generate with scripts/make-dev-initdata.mjs.
# Leave empty in normal use. Never commit a real one.
# VITE_DEV_INIT_DATA=

# Dev-only: preview the full UI with sample data, skipping auth and the
# database entirely. Put this in .env.local when designing screens.
# VITE_DEV_MOCK=1

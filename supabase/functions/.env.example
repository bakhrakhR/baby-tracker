# Secrets for the auth-telegram Edge Function.
#
# Do NOT commit real values. In production, set these with either:
#   npx supabase secrets set TELEGRAM_BOT_TOKEN=... APP_JWT_SECRET=...
# or the dashboard: Project → Edge Functions → Manage secrets.
#
# SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are injected automatically by the
# Edge runtime — do not set them here.

# Bot token from @BotFather (used to verify Telegram initData HMAC).
TELEGRAM_BOT_TOKEN=123456:your-bot-token

# The project's JWT secret, used to sign the Supabase-compatible JWT.
# Dashboard: Project Settings → API → JWT Settings → JWT Secret.
# (Named without the reserved SUPABASE_ prefix so `supabase secrets set` accepts it.)
APP_JWT_SECRET=your-supabase-jwt-secret
